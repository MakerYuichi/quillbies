{
  "expo": {
    "name": "Quillby",
    "slug": "quillby-app",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "quillby",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.quillbyapp"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.quillbyapp",
      "versionCode": 2,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.USE_EXACT_ALARM",
        "com.android.vending.BILLING"
      ],
      "softwareKeyboardLayoutMode": "pan",
      "navigationBar": {
        "visible": false
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#FFD93D",
          "sounds": [],
          "mode": "production",
          "androidMode": "default",
          "androidCollapsedTitle": "Quillby"
        }
      ],
      "expo-localization",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Quillby uses your location once during setup to detect your country and timezone for accurate study reminders.",
          "locationWhenInUsePermission": "Quillby uses your location once during setup to detect your country and timezone for accurate study reminders."
        }
      ],
      "expo-secure-store",
      "./plugins/withHermesEnabled",
      "./plugins/withAndroidX",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0",
            "newArchEnabled": false,
            "useAndroidX": true,
            "enableJetifier": true
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-router",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-4731098262865235~5431550990",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511",
          "userTrackingUsageDescription": "This identifier will be used to deliver personalized ads to you.",
          "skAdNetworkItems": []
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "ee30a0cd-e268-4db5-8626-dbe3ce0bf72c"
      }
    },
    "owner": "makeryuichi"
  }
}
