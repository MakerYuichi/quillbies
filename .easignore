# EAS Build Ignore File
# Exclude unnecessary files to reduce upload size

# Documentation
docs/
*.md
CLEANUP_PLAN.md
CLEANUP_SUMMARY.md
LICENSE

# Test files and directories
__tests__/
tests/
test-build/
test-framework/
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx

# Scripts
scripts/
*.sh

# Git
.git/
.gitignore
.gitattributes

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Build artifacts (not needed for EAS)
dist/
build/
.expo/
android/build/
android/app/build/
android/.gradle/
ios/build/
ios/Pods/

# Environment files (use EAS secrets instead)
.env
.env.local
.env.development
.env.production

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary files
tmp/
temp/
*.tmp

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Thumbnails
._*

# Files that might appear in the root of a volume
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Directories potentially created on remote AFP share
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk
