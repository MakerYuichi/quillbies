# EAS Build Ignore File
# Exclude unnecessary files to reduce upload size

# ============================================
# DOCUMENTATION (NOT NEEDED FOR BUILD)
# ============================================
docs/
*.md
!README.md
CLEANUP_PLAN.md
CLEANUP_SUMMARY.md
PAYWALL_INTEGRATION_COMPLETE.md
MESS_ASSETS_COMPLETE.md
LICENSE

# ============================================
# TEST FILES (NOT NEEDED FOR BUILD)
# ============================================
__tests__/
tests/
test-build/
test-framework/
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
coverage/
.nyc_output/

# ============================================
# SCRIPTS (NOT NEEDED FOR BUILD)
# ============================================
scripts/
*.sh
cleanup-unused-code.sh

# ============================================
# GIT (NOT NEEDED FOR BUILD)
# ============================================
.git/
.gitignore
.gitattributes
.github/

# ============================================
# IDE AND EDITOR FILES
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace

# ============================================
# BUILD ARTIFACTS (NOT NEEDED FOR EAS)
# ============================================
dist/
build/
.expo/
.expo-shared/
android/build/
android/app/build/
android/.gradle/
android/.kotlin/
android/.cxx/
android/app/.cxx/
ios/build/
ios/Pods/
web-build/

# React Native Reanimated build artifacts
node_modules/react-native-reanimated/android/build/
node_modules/react-native-reanimated/android/.cxx/
node_modules/*/android/build/
node_modules/*/android/.cxx/
node_modules/*/ios/build/

# All .cxx directories (CMake build artifacts)
**/.cxx/
**/.gradle/
**/build/intermediates/

# ============================================
# NATIVE FOLDERS (EAS GENERATES THESE)
# ============================================
# Uncomment if you're using managed workflow
# ios/
# android/

# ============================================
# ENVIRONMENT FILES (USE EAS SECRETS)
# ============================================
.env
.env.local
.env.development
.env.production
.env.staging
.env.test
*.env.backup

# ============================================
# LOGS
# ============================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*

# ============================================
# DEPENDENCIES (EAS INSTALLS THESE)
# ============================================
node_modules/
.pnp
.pnp.js

# ============================================
# CACHE AND TEMPORARY FILES
# ============================================
tmp/
temp/
*.tmp
*.cache
.cache/
.parcel-cache/
.metro-health-check*
*.tsbuildinfo
tsconfig.tsbuildinfo

# ============================================
# MACOS
# ============================================
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# ============================================
# WINDOWS
# ============================================
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ============================================
# LINUX
# ============================================
*~
.directory
.Trash-*

# ============================================
# CERTIFICATES AND KEYS (USE EAS SECRETS)
# ============================================
*.pem
*.p8
*.p12
*.key
*.mobileprovision
*.jks
*.keystore
google-services.json
GoogleService-Info.plist

# ============================================
# LARGE MEDIA FILES (IF NOT NEEDED)
# ============================================
# Uncomment if you have large files not needed for build
# *.mp4
# *.mov
# *.avi
# *.psd
# *.ai
# *.sketch

# ============================================
# BACKUP FILES
# ============================================
*.bak
*.backup
*.old
*.orig
*.orig.*

# ============================================
# PACKAGE MANAGER LOCKS (EAS USES THESE)
# ============================================
# Keep package-lock.json and yarn.lock for consistent builds
# !package-lock.json
# !yarn.lock

# ============================================
# MISC
# ============================================
.eslintcache
.stylelintcache
*.swp
*.swo
*~.nib
local.properties
.gradle/