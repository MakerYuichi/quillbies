# Quillby App Environment Variables
# Copy this file to .env and update with your values

# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=your_supabase_url_here
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# RevenueCat Configuration
REVENUE_CAT_API_KEY=your_revenuecat_api_key_here

# Feedback Service Configuration
# Sign up at https://formspree.io/ (free tier available)
# Create a form and paste the endpoint URL here
FORMSPREE_ENDPOINT=https://formspree.io/f/your_form_id

# App Configuration
APP_NAME=Quillby
APP_VERSION=1.0.0
ENVIRONMENT=development

# API Configuration (if you add backend later)
# API_URL=https://api.quillby.app
# API_TIMEOUT=30000

# Feature Flags
ENABLE_NOTIFICATIONS=true
ENABLE_ANALYTICS=false
ENABLE_DEBUG_MODE=true

# Storage
STORAGE_KEY=quillby-storage

# Default Settings
DEFAULT_ENERGY_CAP=100
DEFAULT_STUDY_GOAL_HOURS=3
DEFAULT_WATER_GOAL_GLASSES=8
DEFAULT_SLEEP_GOAL_HOURS=7
DEFAULT_EXERCISE_GOAL_MINUTES=30

# Mess System
MESS_ENERGY_DRAIN_TIME=18
MESS_CHECKPOINT_PENALTY=1

# Energy System
BREAKFAST_PENALTY_TIME=11
BREAKFAST_PENALTY_AMOUNT=10
WATER_ENERGY_BONUS=5
MEAL_ENERGY_BONUS=10
EXERCISE_ENERGY_BONUS=15

# Focus Session
FOCUS_SESSION_BASE_COST=15
DISTRACTION_GRACE_PERIOD=30
DISTRACTION_WARNING_LIMIT=3

# Coins & Rewards
WATER_COIN_REWARD=5
MEAL_COIN_REWARD=10
SLEEP_COIN_REWARD=20
EXERCISE_COIN_PER_MINUTE=1

# Shop Items
COLORED_FAIRY_LIGHTS_PRICE=50
SUCCULENT_PLANT_PRICE=30
SWISS_CHEESE_PLANT_PRICE=40
